# ─── Database ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://app:secret@localhost:5432/kenyan_fintel
DATABASE_URL_SYNC=postgresql://app:secret@localhost:5432/kenyan_fintel

# ─── Security ────────────────────────────────────────────────
SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# ─── AI / LLM ────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ─── Embedding model (local) ─────────────────────────────────
EMBEDDING_MODEL=all-MiniLM-L6-v2
EMBEDDING_DIM=384

# ─── MinIO ───────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET_PDFS=cbk-pdfs
MINIO_BUCKET_REPORTS=fund-reports

# ─── External APIs ───────────────────────────────────────────
NEWS_API_KEY=your-newsapi-key
YAHOO_FINANCE_BASE=https://query1.finance.yahoo.com/v8/finance/chart

# ─── WhatsApp Bot bridge ─────────────────────────────────────
# The Node.js bot calls this FastAPI webhook endpoint
WHATSAPP_WEBHOOK_SECRET=whatsapp-bridge-secret
WHATSAPP_BRIDGE_PORT=3001

# ─── App ─────────────────────────────────────────────────────
APP_NAME=Kenya Financial Intelligence System
DEBUG=true
CORS_ORIGINS=http://localhost:3000,http://localhost:3001
